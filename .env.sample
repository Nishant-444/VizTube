PORT=3000
CORS_ORIGIN=* # add frontend url to make it more secure
ACCESS_TOKEN_EXPIRY=1d
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=10d
REFRESH_TOKEN_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NODE_ENV=development # or production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/viztube?schema=public
DB_USER=postgres
DB_PASS=postgres
DB_NAME=viztube

# AI Worker
AI_WORKER_URL=http://localhost:8000
MAX_TRANSCRIPT_DURATION=120
OPENROUTER_API_KEY= # Required for AI worker RAG queries
GROQ_API_KEY=       # Required for AI worker Whisper transcription